# Copy to .env locally (never commit .env). On Vercel: Project → Settings → Environment Variables.

# Supabase: Dashboard → Project Settings → Database → Connection string → URI
# Use "Direct connection" or "Session pooler" for CREATE TABLE on cold start.
# Transaction pooler (port 6543) also works with this app (prepare_threshold disabled).
#
# Example (replace password and host):
# DATABASE_URL=postgresql://postgres:YOUR_PASSWORD@db.xxxxxxxxxxxx.supabase.co:5432/postgres

DATABASE_URL=

# Optional aliases (if you already use these names in Vercel):
# SUPABASE_DATABASE_URL=
# POSTGRES_URL=
# POSTGRES_URL_NON_POOLING=
# POSTGRES_PRISMA_URL=
